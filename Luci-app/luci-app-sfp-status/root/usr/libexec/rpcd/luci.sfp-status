#!/bin/sh
# TechRef: https://openwrt.org/docs/techref/rpcd

. "${IPKG_INSTROOT}/usr/share/libubox/jshn.sh"

readonly CONFIG_NAME="sfp-status"
readonly ETHTOOL_BIN="${IPKG_INSTROOT}/usr/sbin/ethtool"
readonly CACHE_TTL=5
readonly CACHE_DIR="${IPKG_INSTROOT}/tmp/luci-sfp-status"

cache_key() {
	printf '%s' "${1:-all}" | tr -c 'A-Za-z0-9_.-' '_'
}

cache_file_for() {
	printf '%s/%s-%s.json\n' "$CACHE_DIR" "$1" "$(cache_key "$2")"
}

cache_is_fresh() {
	local file="$1" now mtime age

	[ -r "$file" ] || return 1
	now="$(date +%s 2>/dev/null)" || return 1
	mtime="$(stat -c %Y "$file" 2>/dev/null)" || return 1
	[ -n "$now" ] && [ -n "$mtime" ] || return 1
	age=$((now - mtime))
	[ "$age" -ge 0 ] && [ "$age" -lt "$CACHE_TTL" ]
}

write_cache() {
	local file="$1" content="$2"

	[ -n "$IPKG_INSTROOT" ] && return 0
	mkdir -p "$CACHE_DIR" 2>/dev/null || return 0
	printf '%s\n' "$content" > "$file" 2>/dev/null || true
}

is_valid_interface() {
	printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_.:-]+$'
}

list_interfaces() {
	for iface in $(ls /sys/class/net 2>/dev/null); do
		[ "$iface" = "lo" ] && continue
		echo "$iface"
	done
}

should_probe_interface() {
	local iface="$1"

	case "$iface" in
		''|lo|bonding_masters|br-*|docker*|dummy*|ifb*|teql*|veth*|wg*|wwan*|phy*.*-ap*)
			return 1
			;;
		eth*|lan*|wan*|sfp*)
			return 0
			;;
		*)
			[ -e "/sys/class/net/$iface/device" ]
			return $?
			;;
	esac
}

list_probe_interfaces() {
	local iface

	for iface in $(list_interfaces); do
		should_probe_interface "$iface" || continue
		echo "$iface"
	done
}

current_timestamp() {
	date '+%Y-%m-%d %H:%M:%S'
}

read_field() {
	printf '%s\n' "$1" | awk -v label="$2" '
		{
			line = $0
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
			sep = index(line, ":")
			if (sep > 0) {
				key = substr(line, 1, sep - 1)
				val = substr(line, sep + 1)
				gsub(/[[:space:]]+$/, "", key)
				gsub(/^[[:space:]]+/, "", val)

				if (key == label) {
					print val
					exit
				}
			}
		}
	'
}

read_first_field() {
	local dump="$1" value
	shift

	while [ $# -gt 0 ]; do
		value="$(read_field "$dump" "$1")"
		[ -n "$value" ] && printf '%s\n' "$value" && return 0
		shift
	done

	return 1
}

is_eeprom_dump() {
	[ -n "$1" ] && printf '%s\n' "$1" | grep -Eq '^[[:space:]]*0x[0-9A-Fa-f]{4}:'
}

read_eeprom_bytes() {
	printf '%s\n' "$1" | awk -v start="$2" -v count="$3" '
		function h2d(hex, i, c, n, v) {
			hex = toupper(hex)
			sub(/^0X/, "", hex)
			n = 0
			for (i = 1; i <= length(hex); i++) {
				c = substr(hex, i, 1)
				v = index("0123456789ABCDEF", c) - 1
				if (v < 0)
					v = 0
				n = (n * 16) + v
			}
			return n
		}
		/^[[:space:]]*0x[0-9A-Fa-f]{4}:/ {
			offset = $1
			sub(/:/, "", offset)
			offset = h2d(offset)
			for (i = 2; i <= NF; i++) {
				if ($i ~ /^[0-9A-Fa-f][0-9A-Fa-f]$/) {
					pos = offset + i - 2
					bytes[pos] = toupper($i)
				}
			}
		}
		END {
			for (i = 0; i < count; i++)
				printf "%s%s", i ? " " : "", bytes[start + i]
			printf "\n"
		}
	'
}

read_eeprom_text() {
	printf '%s\n' "$1" | awk -v start="$2" -v count="$3" '
		function h2d(hex, i, c, n, v) {
			hex = toupper(hex)
			sub(/^0X/, "", hex)
			n = 0
			for (i = 1; i <= length(hex); i++) {
				c = substr(hex, i, 1)
				v = index("0123456789ABCDEF", c) - 1
				if (v < 0)
					v = 0
				n = (n * 16) + v
			}
			return n
		}
		/^[[:space:]]*0x[0-9A-Fa-f]{4}:/ {
			offset = $1
			sub(/:/, "", offset)
			offset = h2d(offset)
			for (i = 2; i <= NF; i++) {
				if ($i ~ /^[0-9A-Fa-f][0-9A-Fa-f]$/) {
					pos = offset + i - 2
					bytes[pos] = h2d($i)
				}
			}
		}
		END {
			for (i = 0; i < count; i++) {
				value = bytes[start + i]
				text = text ((value >= 32 && value <= 126) ? sprintf("%c", value) : " ")
			}
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", text)
			gsub(/[[:space:]]+/, " ", text)
			print text
		}
	'
}

read_eeprom_byte_dec() {
	read_eeprom_bytes "$1" "$2" 1 | awk '
		function h2d(hex, i, c, n, v) {
			hex = toupper(hex)
			n = 0
			for (i = 1; i <= length(hex); i++) {
				c = substr(hex, i, 1)
				v = index("0123456789ABCDEF", c) - 1
				if (v < 0)
					v = 0
				n = (n * 16) + v
			}
			return n
		}
		NF { print h2d($1) }
	'
}

read_eeprom_word_dec() {
	read_eeprom_bytes "$1" "$2" 2 | awk '
		function h2d(hex, i, c, n, v) {
			hex = toupper(hex)
			n = 0
			for (i = 1; i <= length(hex); i++) {
				c = substr(hex, i, 1)
				v = index("0123456789ABCDEF", c) - 1
				if (v < 0)
					v = 0
				n = (n * 16) + v
			}
			return n
		}
		NF >= 2 { print (h2d($1) * 256) + h2d($2) }
	'
}

format_decimal() {
	awk -v value="$1" -v scale="$2" -v suffix="$3" -v precision="$4" 'BEGIN {
		if (value == "" || scale == "" || scale == 0)
			exit
		if (precision == "")
			precision = 2
		printf "%.*f%s\n", precision, value / scale, suffix
	}'
}

format_signed_temperature() {
	awk -v value="$1" 'BEGIN {
		if (value == "")
			exit
		if (value >= 32768)
			value -= 65536
		printf "%.2f C\n", value / 256
	}'
}

eeprom_identifier_name() {
	case "$1" in
		1) printf 'GBIC\n' ;;
		2) printf 'Module soldered to motherboard\n' ;;
		3) printf 'SFP/SFP+/SFP28\n' ;;
		11) printf 'QSFP\n' ;;
		12) printf 'QSFP+\n' ;;
		13) printf 'CXP\n' ;;
		17) printf 'QSFP28\n' ;;
		*) [ -n "$1" ] && printf 'Identifier 0x%02X\n' "$1" ;;
	esac
}

get_speed() {
	local iface="$1"
	local link_dump speed

	link_dump="$($ETHTOOL_BIN "$iface" 2>/dev/null)"
	speed="$(read_field "$link_dump" 'Speed')"

	if [ -z "$speed" ] && [ -r "/sys/class/net/$iface/speed" ]; then
		speed="$(cat "/sys/class/net/$iface/speed" 2>/dev/null)"
		[ -n "$speed" ] && [ "$speed" != "-1" ] && speed="${speed}Mb/s"
	fi

	printf '%s\n' "$speed"
}

is_dom_capable_dump() {
	[ -n "$1" ] && { is_eeprom_dump "$1" || printf '%s\n' "$1" | grep -Eiq 'Identifier|Vendor[[:space:]]+(name|PN|SN|part|serial)|Module[[:space:]]+(temperature|voltage)|Temperature|Voltage|Bias[[:space:]]+current|Laser[[:space:]]+(bias|output|wavelength)|Receiver[[:space:]]+signal|RX[[:space:]]+Power|TX[[:space:]]+Power|Optical[[:space:]]+(diagnostics|power)|Wavelength'; }
}

module_slot_for_interface() {
	local interface="$1"

	case "$interface" in
		*[0-9])
			printf 'SFP%s\n' "${interface##*[!0-9]}"
			;;
		*)
			printf '%s\n' "$interface" | tr '[:lower:]' '[:upper:]'
			;;
	esac
}

json_add_unsupported_status() {
	local interface="$1"
	local speed="$2"
	local error="$3"

	json_add_boolean supported 0
	[ -n "$interface" ] && json_add_string interface "$interface"
	[ -n "$interface" ] && json_add_string module_slot "$(module_slot_for_interface "$interface")"
	[ -n "$speed" ] && json_add_string speed "$speed"
	json_add_string error "$error"
}

json_add_supported_status() {
	local interface="$1"
	local auto_detected="$2"
	local dom_dump="$3"
	local link_dump="$4"
	local speed="$5"
	local identifier vendor_name vendor_part vendor_revision serial wavelength
	local temperature voltage bias_current rx_power tx_power duplex port link_detected
	local module_name module_slot identifier_code source

	identifier="$(read_first_field "$dom_dump" 'Identifier' 'Transceiver type')"
	vendor_name="$(read_first_field "$dom_dump" 'Vendor name' 'Vendor Name')"
	vendor_part="$(read_first_field "$dom_dump" 'Vendor PN' 'Vendor part number' 'Vendor part' 'Vendor Part Number')"
	vendor_revision="$(read_first_field "$dom_dump" 'Vendor rev' 'Vendor revision' 'Vendor Rev')"
	serial="$(read_first_field "$dom_dump" 'Vendor SN' 'Vendor serial number' 'Vendor Serial Number')"
	wavelength="$(read_first_field "$dom_dump" 'Laser wavelength' 'Wavelength')"
	temperature="$(read_first_field "$dom_dump" 'Module temperature' 'Temperature')"
	voltage="$(read_first_field "$dom_dump" 'Module voltage' 'Voltage')"
	bias_current="$(read_first_field "$dom_dump" 'Laser bias current' 'Bias current' 'TX bias current' 'Tx bias current')"
	rx_power="$(read_first_field "$dom_dump" 'Receiver signal average optical power' 'Receiver signal OMA' 'RX Power' 'Rx Power' 'RX power' 'Rx power' 'Optical receive power')"
	tx_power="$(read_first_field "$dom_dump" 'Laser output power' 'TX Power' 'Tx Power' 'TX power' 'Tx power' 'Optical transmit power')"

	if is_eeprom_dump "$dom_dump"; then
		identifier_code="$(read_eeprom_byte_dec "$dom_dump" 0)"
		[ -z "$identifier" ] && identifier="$(eeprom_identifier_name "$identifier_code")"
		[ -z "$vendor_name" ] && vendor_name="$(read_eeprom_text "$dom_dump" 20 16)"
		[ -z "$vendor_part" ] && vendor_part="$(read_eeprom_text "$dom_dump" 40 16)"
		[ -z "$vendor_revision" ] && vendor_revision="$(read_eeprom_text "$dom_dump" 56 4)"
		[ -z "$serial" ] && serial="$(read_eeprom_text "$dom_dump" 68 16)"
		[ -z "$temperature" ] && temperature="$(format_signed_temperature "$(read_eeprom_word_dec "$dom_dump" 352)")"
		[ -z "$voltage" ] && voltage="$(format_decimal "$(read_eeprom_word_dec "$dom_dump" 354)" 10000 ' V' 2)"
		[ -z "$bias_current" ] && bias_current="$(format_decimal "$(read_eeprom_word_dec "$dom_dump" 356)" 500 ' mA' 2)"
		[ -z "$tx_power" ] && tx_power="$(format_decimal "$(read_eeprom_word_dec "$dom_dump" 358)" 10000 ' mW' 4)"
		[ -z "$rx_power" ] && rx_power="$(format_decimal "$(read_eeprom_word_dec "$dom_dump" 360)" 10000 ' mW' 4)"
	fi

	duplex="$(read_field "$link_dump" 'Duplex')"
	port="$(read_field "$link_dump" 'Port')"
	link_detected="$(read_field "$link_dump" 'Link detected')"
	source='ethtool DOM'
	is_eeprom_dump "$dom_dump" && source='ethtool EEPROM'

	module_name="$vendor_name"
	[ -n "$vendor_part" ] && module_name="${module_name:+$module_name }$vendor_part"
	[ -z "$module_name" ] && module_name="$identifier"
	module_slot="$(module_slot_for_interface "$interface")"

	json_add_boolean supported 1
	json_add_boolean auto_detected "$auto_detected"
	json_add_boolean link_up "$([ "$link_detected" = 'yes' ] && echo 1 || echo 0)"
	json_add_string interface "$interface"
	json_add_string module_slot "$module_slot"
	json_add_string module_name "$module_name"
	json_add_string identifier "$identifier"
	json_add_string vendor_name "$vendor_name"
	json_add_string vendor_part "$vendor_part"
	json_add_string vendor_revision "$vendor_revision"
	json_add_string serial "$serial"
	json_add_string wavelength "$wavelength"
	json_add_string temperature "$temperature"
	json_add_string voltage "$voltage"
	json_add_string bias_current "$bias_current"
	json_add_string rx_power "$rx_power"
	json_add_string tx_power "$tx_power"
	json_add_string speed "$speed"
	json_add_string duplex "$duplex"
	json_add_string port "$port"
	json_add_string source "$source"
}

auto_detect_interface() {
	local iface dom_dump

	for iface in $(list_probe_interfaces); do
		dom_dump="$($ETHTOOL_BIN -m "$iface" 2>/dev/null)"
		if is_dom_capable_dump "$dom_dump"; then
			printf '%s\n' "$iface"
			return 0
		fi
	done

	return 1
}

json_add_interfaces() {
	json_add_array interfaces
	for iface in $(list_sfp_interfaces); do
		json_add_string '' "$iface"
	done
	json_close_array
}

list_sfp_interfaces() {
	local iface dom_dump

	[ -x "$ETHTOOL_BIN" ] || return 0

	for iface in $(list_probe_interfaces); do
		dom_dump="$($ETHTOOL_BIN -m "$iface" 2>/dev/null)"
		is_dom_capable_dump "$dom_dump" || continue
		echo "$iface"
	done
}

build_interfaces_json() {
	json_init
	json_add_interfaces
	json_add_int cache_ttl "$CACHE_TTL"
	json_dump
	json_cleanup
}

get_interfaces() {
	local cache_file output

	cache_file="$(cache_file_for getInterfaces all)"
	if cache_is_fresh "$cache_file"; then
		cat "$cache_file"
		return 0
	fi

	output="$(build_interfaces_json)"
	printf '%s\n' "$output"
	write_cache "$cache_file" "$output"
}

build_status_json() {
	local requested_interface="$1"
	local interface auto_detected dom_dump link_dump speed

	interface="$requested_interface"
	auto_detected=0

	if [ -n "$interface" ] && ! is_valid_interface "$interface"; then
		interface=''
	fi

	if [ -z "$interface" ]; then
		interface="$(auto_detect_interface)"
		[ -n "$interface" ] && auto_detected=1
	fi

	json_init
	json_add_interfaces
	json_add_string sampled_at "$(current_timestamp)"
	json_add_int cache_ttl "$CACHE_TTL"

	if [ ! -x "$ETHTOOL_BIN" ]; then
		json_add_boolean supported 0
		json_add_string error 'ethtool is not installed'
		json_dump
		json_cleanup
		return 0
	fi

	if [ -z "$interface" ]; then
		json_add_boolean supported 0
		json_add_string error 'No SFP DOM capable interface was detected.'
		json_dump
		json_cleanup
		return 0
	fi

	dom_dump="$($ETHTOOL_BIN -m "$interface" 2>/dev/null)"
	link_dump="$($ETHTOOL_BIN "$interface" 2>/dev/null)"
	speed="$(get_speed "$interface")"

	if ! is_dom_capable_dump "$dom_dump"; then
		json_add_unsupported_status "$interface" "$speed" 'SFP DOM data is not available on the selected interface.'
		json_dump
		json_cleanup
		return 0
	fi

	json_add_supported_status "$interface" "$auto_detected" "$dom_dump" "$link_dump" "$speed"
	json_dump
	json_cleanup
}

get_status() {
	local requested_interface="$1" interface cache_file output

	interface="$requested_interface"
	if [ -n "$interface" ] && ! is_valid_interface "$interface"; then
		interface=''
	fi

	cache_file="$(cache_file_for getStatus "${interface:-auto}")"
	if cache_is_fresh "$cache_file"; then
		cat "$cache_file"
		return 0
	fi

	output="$(build_status_json "$interface")"
	printf '%s\n' "$output"
	write_cache "$cache_file" "$output"
}

build_statuses_json() {
	local requested_interface="$1"
	local interface auto_detected dom_dump link_dump speed has_modules

	interface="$requested_interface"
	auto_detected=0
	has_modules=0

	if [ -n "$interface" ] && ! is_valid_interface "$interface"; then
		interface=''
	fi

	json_init
	json_add_interfaces
	json_add_string sampled_at "$(current_timestamp)"
	json_add_int cache_ttl "$CACHE_TTL"

	if [ ! -x "$ETHTOOL_BIN" ]; then
		json_add_array modules
		json_close_array
		json_add_boolean supported 0
		json_add_string error 'ethtool is not installed'
		json_dump
		json_cleanup
		return 0
	fi

	json_add_array modules

	if [ -n "$interface" ]; then
		dom_dump="$($ETHTOOL_BIN -m "$interface" 2>/dev/null)"
		link_dump="$($ETHTOOL_BIN "$interface" 2>/dev/null)"
		speed="$(get_speed "$interface")"

		json_add_object ''
		if is_dom_capable_dump "$dom_dump"; then
			json_add_supported_status "$interface" 0 "$dom_dump" "$link_dump" "$speed"
			has_modules=1
		else
			json_add_unsupported_status "$interface" "$speed" 'SFP DOM data is not available on the selected interface.'
		fi
		json_close_object
	else
		for interface in $(list_probe_interfaces); do
			dom_dump="$($ETHTOOL_BIN -m "$interface" 2>/dev/null)"
			if ! is_dom_capable_dump "$dom_dump"; then
				continue
			fi

			link_dump="$($ETHTOOL_BIN "$interface" 2>/dev/null)"
			speed="$(get_speed "$interface")"

			json_add_object ''
			json_add_supported_status "$interface" 1 "$dom_dump" "$link_dump" "$speed"
			json_close_object
			has_modules=1
			auto_detected=1
		done
	fi

	json_close_array
	json_add_boolean supported "$has_modules"
	json_add_boolean auto_detected "$auto_detected"

	if [ "$has_modules" != "1" ] && [ -z "$requested_interface" ]; then
		json_add_string error 'No SFP DOM capable interface was detected.'
	fi

	json_dump
	json_cleanup
}

get_statuses() {
	local requested_interface="$1" interface cache_file output

	interface="$requested_interface"
	if [ -n "$interface" ] && ! is_valid_interface "$interface"; then
		interface=''
	fi

	cache_file="$(cache_file_for getStatuses "${interface:-all}")"
	if cache_is_fresh "$cache_file"; then
		cat "$cache_file"
		return 0
	fi

	output="$(build_statuses_json "$interface")"
	printf '%s\n' "$output"
	write_cache "$cache_file" "$output"
}

case "$1" in
	list)
		json_init
		json_add_object getInterfaces
		json_close_object
		json_add_object getStatus
			json_add_string interface string
		json_close_object
		json_add_object getStatuses
			json_add_string interface string
		json_close_object
		json_dump
		json_cleanup
		;;
	call)
		case "$2" in
			getInterfaces)
				get_interfaces
				;;
			getStatus)
				input="$(cat)"
				if [ -n "$input" ]; then
					json_load "$input"
					json_get_var interface interface
					json_cleanup
				fi
				get_status "$interface"
				;;
			getStatuses)
				input="$(cat)"
				if [ -n "$input" ]; then
					json_load "$input"
					json_get_var interface interface
					json_cleanup
				fi
				get_statuses "$interface"
				;;
		esac
		;;
esac