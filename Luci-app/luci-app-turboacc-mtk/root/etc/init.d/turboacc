#!/bin/sh /etc/rc.common
# Copyright (C) 2018 Lean <coolsnowwolf@gmail.com>
# Copyright (C) 2019-2022 Tianling Shen <cnsztl@immortalwrt.org>

START=90
STOP=10
USE_PROCD=1

module_loaded() {
	local module

	for module in "$@"; do
		[ -d "/sys/module/$module" ] && return 0
	done

	return 1
}

try_modprobe() {
	local module

	for module in "$@"; do
		modprobe "$module" 2>"/dev/null" && return 0
	done

	return 1
}

hnat_module_loaded() {
	module_loaded "mtkhnat" "mediatek_hnat"
}

load_hnat_module() {
	try_modprobe "mtkhnat" "mediatek_hnat"
}

is_valid_ipv4() {
	echo "$1" | grep -qE '^([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

append_unique_token() {
	local list="$1"
	local token="$2"

	case " $list " in
	*" $token "*)
		printf '%s\n' "$list"
		;;
	*)
		if [ -n "$list" ]; then
			printf '%s %s\n' "$list" "$token"
		else
			printf '%s\n' "$token"
		fi
		;;
	esac
}

is_ap_candidate_port() {
	case "$1" in
	''|br-*|@*|lo|pppoe-*|wg*|tun*|tap*|gre*|gretap*|sit*|ifb*|veth*|docker*|*.*)
		return 1
		;;
	*)
		return 0
		;;
	esac
}

list_ap_candidate_ports() {
	local devices=""
	local device

	for device in $(uci show network 2>"/dev/null" | sed -n "s/^network\.[^.]*\.device='\([^']*\)'$/\1/p"); do
		if is_ap_candidate_port "$device"; then
			devices="$(append_unique_token "$devices" "$device")"
		fi
	done

	if [ -z "$devices" ]; then
		devices="eth0 eth1 wan"
	fi

	printf '%s\n' "$devices"
}

default_fullcone_mode() {
	if [ -e "/lib/modules/$(uname -r)/xt_FULLCONENAT.ko" ]; then
		printf '1\n'
	else
		printf '2\n'
	fi
}

find_lan_device_section() {
	local lan_device
	local lan_section
	local section
	local name

	lan_device="$(uci -q get network.lan.device)"
	[ -n "$lan_device" ] || return 1

	for section in $(uci show network 2>"/dev/null" | sed -n 's/^network\.\(@device\[[0-9]*\]\)=device$/\1/p'); do
		name="$(uci -q get network.$section.name)"
		if [ "$name" = "$lan_device" ]; then
			lan_section="$section"
			break
		fi
	done

	[ -n "$lan_section" ] || return 1

	printf '%s\n' "$lan_section"
}

start_service() {
	config_load "turboacc"

	local fastpath
	local hnat_path="/sys/kernel/debug/hnat"
	local fastpath_mh_eth_hnat="0"
	local fastpath_mh_eth_hnat_ap=""
	config_get fastpath "config" "fastpath"
	[ -n "$fastpath" ] || fastpath="none"

	if [ "$fastpath" != "fast_classifier" ] && lsmod | grep -q "fast_classifier"; then
		echo "0" > "/sys/fast_classifier/skip_to_bridge_ingress" 2>"/dev/null"
		rm -f "/dev/sfe_ipv6"
		rmmod "fast_classifier" 2>"/dev/null"
	fi

	if [ "$fastpath" != "shortcut_fe_cm" ] && lsmod | grep -q "shortcut_fe_cm"; then
		rmmod "shortcut_fe_cm" 2>"/dev/null"
	fi

	if [ "$fastpath" != "mediatek_hnat" ] && hnat_module_loaded && [ -e "$hnat_path/hook_toggle" ]; then
		echo "0" > "$hnat_path/hook_toggle" 2>"/dev/null"
	fi

	case "$fastpath" in
	"fast_classifier")
		local fastpath_fc_br fastpath_fc_ipv6
		config_get_bool fastpath_fc_br "config" "fastpath_fc_br" "0"
		config_get_bool fastpath_fc_ipv6 "config" "fastpath_fc_ipv6" "0"

		lsmod | grep -q "fast_classifier" || modprobe "fast_classifier" 2>"/dev/null"
		echo "$fastpath_fc_br" > "/sys/fast_classifier/skip_to_bridge_ingress" 2>"/dev/null"
		if [ "$fastpath_fc_ipv6" -eq "1" ]; then
			[ -e "/dev/sfe_ipv6" ] || mknod "/dev/sfe_ipv6" "c" "$(cat "/sys/sfe_ipv6/debug_dev")" "0"
		else
			[ ! -e "/dev/sfe_ipv6" ] || rm -f "/dev/sfe_ipv6"
		fi
		;;
	"shortcut_fe_cm")
		lsmod |grep -q "shortcut_fe_cm" || modprobe "shortcut_fe_cm" 2>"/dev/null"
		;;
	"mediatek_hnat")
		config_get_bool fastpath_mh_eth_hnat "config" "fastpath_mh_eth_hnat" "1"
		load_hnat_module
		[ -e "$hnat_path/hook_toggle" ] && echo "$fastpath_mh_eth_hnat" > "$hnat_path/hook_toggle" 2>"/dev/null"

		if [ "$fastpath_mh_eth_hnat" -eq "1" ]; then
			local fastpath_mh_eth_hnat_v6 fastpath_mh_eth_hnat_bind_rate

			config_get_bool fastpath_mh_eth_hnat_v6 "config" "fastpath_mh_eth_hnat_v6" "1"
			[ -e "$hnat_path/hnat_setting" ] && echo "8 $fastpath_mh_eth_hnat_v6" > "$hnat_path/hnat_setting" 2>"/dev/null"

			config_get fastpath_mh_eth_hnat_bind_rate "config" "fastpath_mh_eth_hnat_bind_rate" "30"
			[ -e "$hnat_path/hnat_setting" ] && echo "7 $fastpath_mh_eth_hnat_bind_rate" > "$hnat_path/hnat_setting" 2>"/dev/null"

			config_get fastpath_mh_eth_hnat_ap "config" "fastpath_mh_eth_hnat_ap" ""
		fi
		;;
	esac

	local fullcone
	config_get "fullcone" "config" "fullcone" "$(default_fullcone_mode)"
		if [ -w "/proc/sys/net/netfilter/nf_conntrack_nat_mode" ]; then
			echo "$fullcone" > "/proc/sys/net/netfilter/nf_conntrack_nat_mode"
		fi

	local tcpcca
	config_get "tcpcca" "config" "tcpcca" "cubic"
	sysctl -w net.ipv4.tcp_congestion_control="$tcpcca" >"/dev/null"

	uci -q commit "firewall"
	/etc/init.d/firewall restart >"/dev/null" 2>&1
	if [ "$fastpath" = "mediatek_hnat" ] && [ "$fastpath_mh_eth_hnat" -eq "1" ] && [ -n "$fastpath_mh_eth_hnat_ap" ]; then
		local available_interfaces
		local current_ports
		local new_ports
		local lan_device_section
		local port
		local wifi_iface

		available_interfaces="$(list_ap_candidate_ports)"

		if is_valid_ipv4 "$fastpath_mh_eth_hnat_ap"; then
			uci delete network.wan
			uci delete network.wwan
			uci delete network.wan6

			lan_device_section="$(find_lan_device_section 2>"/dev/null")"
			if [ -n "$lan_device_section" ]; then
				current_ports="$(uci get "network.$lan_device_section.ports" 2>"/dev/null")"
				new_ports="$current_ports"

				for port in $available_interfaces; do
					if ! echo "$current_ports" | grep -qw "$port"; then
						new_ports="$new_ports $port"
					fi
				done

				uci set "network.$lan_device_section.ports=$new_ports"
			fi

			uci set dhcp.lan.ignore=1
			uci set network.lan.ipaddr="$fastpath_mh_eth_hnat_ap"

			for wifi_iface in $(uci show wireless 2>"/dev/null" | sed -n 's/^wireless\.\([^.=]*\)=wifi-iface$/\1/p'); do
				uci set "wireless.$wifi_iface.network=lan"
			done

			uci commit network
			uci commit wireless
			uci commit dhcp
		fi
	fi
}

reload_service() {
	start_service
}

stop_service() {
	if [ -e "/sys/kernel/debug/hnat/hook_toggle" ]; then
		echo "0" > "/sys/kernel/debug/hnat/hook_toggle" 2>"/dev/null"
	fi
}

service_triggers() {
        procd_add_reload_trigger "turboacc"
}
