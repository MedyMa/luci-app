local json = require "luci.jsonc"
local fs   = require "nixio.fs"
local util = require "luci.util"
local sys  = require "luci.sys"

string.trim = util.trim

local function readfile(path)
	local s = fs.readfile(path)
	return s and (s:gsub("^%s+", ""):gsub("%s+$", ""))
end

local function module_file_exists(kernel, names)
	local name

	if not kernel or kernel == "" then
		return false
	end

	for _, name in ipairs(names) do
		if fs.access("/lib/modules/" .. kernel .. "/" .. name .. ".ko") or
			fs.access("/lib/modules/" .. kernel .. "/" .. name .. ".ko.gz") or
			fs.access("/lib/modules/" .. kernel .. "/" .. name .. ".ko.xz") or
			fs.access("/lib/modules/" .. kernel .. "/" .. name .. ".ko.zst")
		then
			return true
		end
	end

	return false
end

local function module_loaded(names)
	local name

	for _, name in ipairs(names) do
		if fs.stat("/sys/module/" .. name, "type") == "dir" then
			return true
		end
	end

	return false
end

local function is_hnat_enabled(value)
	value = (value or ""):lower()

	return value == "1" or value == "enabled" or value == "enable" or
		value == "on" or value == "true" or value == "y" or value == "yes"
end

local function hnat_hook_enabled()
	return is_hnat_enabled(readfile("/sys/kernel/debug/hnat/hook_toggle"))
end

local function has_mediatek_wireless_dat()
	return fs.stat("/etc/wireless/mediatek", "type") == "dir" and
		sys.call("set -- /etc/wireless/mediatek/*.dat; [ -e \"$1\" ]") == 0
end

local methods = {
	getSystemFeatures = {
		call = function()
			local boardinfo = util.ubus("system", "board") or {}
			local kernel    = tostring(boardinfo.kernel or "")
			local features  = {
				hasIPV6           = fs.access("/proc/net/ipv6_route"),
				-- mt798x primary path is HNAT; other engines are user-selectable (kernel modules may be absent, init script handles gracefully)
				hasFLOWOFFLOADING = true,
				hasFASTCLASSIFIER = true,
				hasSHORTCUTFECM   = true,
				hasMEDIATEKHNAT   = module_file_exists(kernel, { "mtkhnat", "mediatek_hnat" }) or
					module_loaded({ "mtkhnat", "mediatek_hnat" }) or
					fs.stat("/sys/kernel/debug/hnat", "type") == "dir",
				hasXTFULLCONENAT  = module_file_exists(kernel, { "xt_FULLCONENAT" }) or module_loaded({ "xt_FULLCONENAT" }),
				hasTCPCCA         = readfile("/proc/sys/net/ipv4/tcp_available_congestion_control")
			}
			print(json.stringify(features))
		end
	},
	getFastPathStat = {
		call = function()
			local fptype
			if fs.access("/sys/module/xt_FLOWOFFLOAD/refcnt") and
			(readfile("/sys/module/xt_FLOWOFFLOAD/refcnt") or "0") ~= "0" then
				fptype = "Flow offloading"
			elseif fs.stat("/sys/module/fast_classifier", "type") == "dir" then
				fptype = "Fast classifier"
			elseif fs.stat("/sys/module/shortcut_fe_cm", "type") == "dir" then
				fptype = "Shortcut-FE CM"
			elseif (fs.stat("/sys/kernel/debug/hnat", "type") == "dir" or module_loaded({ "mtkhnat", "mediatek_hnat" })) and
				hnat_hook_enabled()
			then
				local hnat_note = ""

				if has_mediatek_wireless_dat() and
					sys.call("grep -q 'WHNAT=1' /etc/wireless/mediatek/*.dat") ~= 0
				then
					hnat_note = " / HNAT Partially Enabled"
				end

				fptype = "MediaTek HNAT" .. hnat_note
			end
			print(json.stringify({ type = fptype }))
		end
	},
	getFullConeStat = {
		call = function()
			local fctype
			if fs.access("/sys/module/xt_FULLCONENAT/refcnt") and
			(readfile("/sys/module/xt_FULLCONENAT/refcnt") or "0") ~= "0" then
				fctype = "xt_FULLCONENAT"
			elseif  fs.access("/proc/sys/net/netfilter/nf_conntrack_nat_mode") and
				(readfile("/proc/sys/net/netfilter/nf_conntrack_nat_mode") or "0") ~= "0" then
				fctype = "Boardcom Fullcone"
			end
			print(json.stringify({ type = fctype }))
		end
	},
	getTCPCCAStat = {
		call = function()
			local ccatype = readfile("/proc/sys/net/ipv4/tcp_congestion_control")
			ccatype = ccatype and ccatype:upper() or nil
			print(json.stringify({ type = ccatype }))
		end
	},
	getMTKPPEStat = {
		call = function()
			local ppe_stat = {}
			local ppe_path = "/sys/kernel/debug/hnat/hnat_stats"

			if not hnat_hook_enabled() then
				ppe_stat.PPE_NUM = "0"
				print(json.stringify(ppe_stat))
				return
			end

			if not fs.access(ppe_path) then
				-- try alternate locations
				local alts = {
					"/sys/kernel/debug/hnat/hnat_stats",
					"/sys/kernel/debug/mtk_hnat/hnat_stats",
					"/sys/kernel/debug/ppe0/bind"
				}
				local found = false
				for _, alt in ipairs(alts) do
					if fs.access(alt) then
						ppe_path = alt
						found = true
						break
					end
				end
				if not found then
					ppe_stat.PPE_NUM = "0"
					print(json.stringify(ppe_stat))
					return
				end
			end

			local function ensure_ppe(index)
				index = tonumber(index or "")
				if not index then
					return nil
				end

				local current = tonumber(ppe_stat.PPE_NUM or "0") or 0
				if index + 1 > current then
					ppe_stat.PPE_NUM = tostring(index + 1)
				end

				return tostring(index)
			end

			local function set_ppe_value(kind, index, value)
				index = ensure_ppe(index)
				value = tonumber(value or "")
				if index and value then
					ppe_stat[kind .. "_PPE" .. index] = tostring(value)
				end
			end

			local function parse_compact_ppe_line(line)
				local ppe = line:match("[Pp][Pp][Ee]%s*(%d+)")
				local value

				if not ppe then
					return
				end

				value = line:match("[Bb][Ii][Nn][Dd]%w*%s*[:=]%s*(%d+)") or
					line:match("[Bb][Oo][Uu][Nn][Dd]%w*%s*[:=]%s*(%d+)") or
					line:match("[Bb][Ii][Nn][Dd]%w*%s+(%d+)") or
					line:match("[Bb][Oo][Uu][Nn][Dd]%w*%s+(%d+)")
				set_ppe_value("BIND", ppe, value)

				value = line:match("[Aa][Ll][Ll]%w*%s*[:=]%s*(%d+)") or
					line:match("[Ee][Nn][Tt][Rr][Yy]%w*%s*[:=]%s*(%d+)") or
					line:match("[Ee][Nn][Tt][Rr][Ii][Ee][Ss]%w*%s*[:=]%s*(%d+)") or
					line:match("[Tt][Oo][Tt][Aa][Ll]%w*%s*[:=]%s*(%d+)") or
					line:match("[Aa][Ll][Ll]%w*%s+(%d+)") or
					line:match("[Ee][Nn][Tt][Rr][Yy]%w*%s+(%d+)") or
					line:match("[Ee][Nn][Tt][Rr][Ii][Ee][Ss]%w*%s+(%d+)") or
					line:match("[Tt][Oo][Tt][Aa][Ll]%w*%s+(%d+)")
				set_ppe_value("ALL", ppe, value)
			end

			local fd = io.open(ppe_path, 'r')

			if fd then
				for line in fd:lines() do
					local i = string.find(line, "=")
					if i then
						local key = (string.sub(line, 1, i - 1):gsub("^%s+", ""):gsub("%s+$", ""))
						local value = (string.sub(line, i + 1):gsub("^%s+", ""):gsub("%s+$", ""))
						local ppe, kind = key:match("^[Pp][Pp][Ee]%s*(%d+)%s*[_%-%s%.]*(.+)$")
						local reverse_kind, reverse_ppe = key:match("^(.+)%s*[_%-%s%.]*[Pp][Pp][Ee]%s*(%d+)$")

						if ppe and kind then
							kind = kind:lower()

							if kind:match("bind") or kind:match("bound") then
								set_ppe_value("BIND", ppe, value)
							elseif kind:match("all") or kind:match("entry") or kind:match("entries") or kind:match("total") then
								set_ppe_value("ALL", ppe, value)
							else
								ppe_stat[key] = value
							end
						elseif reverse_kind and reverse_ppe then
							reverse_kind = reverse_kind:lower()

							if reverse_kind:match("bind") or reverse_kind:match("bound") then
								set_ppe_value("BIND", reverse_ppe, value)
							elseif reverse_kind:match("all") or reverse_kind:match("entry") or reverse_kind:match("entries") or reverse_kind:match("total") then
								set_ppe_value("ALL", reverse_ppe, value)
							else
								ppe_stat[key] = value
							end
						else
							ppe_stat[key] = value
						end
					else
						parse_compact_ppe_line(line)
					end
				end
				fd:close()
			end

			if ppe_stat.PPE_NUM then
				local count = tonumber(ppe_stat.PPE_NUM) or 0
				for index = 0, count - 1 do
					ppe_stat["BIND_PPE" .. index] = ppe_stat["BIND_PPE" .. index] or "0"
					ppe_stat["ALL_PPE" .. index] = ppe_stat["ALL_PPE" .. index] or "0"
				end
			end

			print(json.stringify(ppe_stat))
		end
	}
}

local function parseInput()
	local parse = json.new()
	local done, err

	while true do
		local chunk = io.read(4096)
		if not chunk then
			break
		elseif not done and not err then
			done, err = parse:parse(chunk)
		end
	end

	if not done then
		print(json.stringify({ error = err or "Incomplete input" }))
		os.exit(1)
	end

	return parse:get()
end

local function validateArgs(func, uargs)
	local method = methods[func]
	if not method then
		print(json.stringify({ error = "Method not found" }))
		os.exit(1)
	end

	if type(uargs) ~= "table" then
		print(json.stringify({ error = "Invalid arguments" }))
		os.exit(1)
	end

	uargs.ubus_rpc_session = nil

	local k, v
	local margs = method.args or {}
	for k, v in pairs(uargs) do
		if margs[k] == nil or
		   (v ~= nil and type(v) ~= type(margs[k]))
		then
			print(json.stringify({ error = "Invalid arguments" }))
			os.exit(1)
		end
	end

	return method
end

if arg[1] == "list" then
	local _, method, rv = nil, nil, {}
	for _, method in pairs(methods) do rv[_] = method.args or {} end
	print((json.stringify(rv):gsub(":%[%]", ":{}")))
elseif arg[1] == "call" then
	local args = parseInput()
	local method = validateArgs(arg[2], args)
	method.call(args)
	os.exit(0)
end
