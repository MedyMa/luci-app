config AdGuardHome 'AdGuardHome'
	option enabled '0'
	option waitonboot '1'
	option update '1'
	option httpport '3000'
	option redirect 'dnsmasq-upstream'
	option passwall_upstream_auto '0'
	option configpath '/etc/config/adGuardConfig/AdGuardHome.yaml'
	option workdir '/etc/config/adGuardConfig/workspace'
	option logfile '/tmp/AdGuardHome.log'
	option verbose '0'
	option binpath '/etc/config/adGuardConfig/AdGuardHome'
	option upxflag ''
	option downloadarch 'auto'
	option release_channel 'release'
	option tagname 'release'
	option arch ''
	option gfw '0'
	option gfwipset '0'
	option gfwupstream 'tcp://208.67.220.220:5353'
	option backup '0'
	option username 'root'
	option password 'admin'
