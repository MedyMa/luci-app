#!/bin/sh

. "${IPKG_INSTROOT}/usr/share/libubox/jshn.sh"

CONFIG_NAME='AdGuardHome'
DEFAULT_BINPATH='/etc/config/adGuardConfig/AdGuardHome'
DEFAULT_CONFIGPATH='/etc/config/adGuardConfig/AdGuardHome.yaml'
DEFAULT_WORKDIR='/etc/config/adGuardConfig/workspace'
DEFAULT_REDIRECT='dnsmasq-upstream'
LINKS_FILE="${IPKG_INSTROOT}/usr/share/AdGuardHome/links.txt"
TEMPLATE_FILE="${IPKG_INSTROOT}/usr/share/AdGuardHome/AdGuardHome_template.yaml"
TEMP_CONFIG='/tmp/AdGuardHometmpconfig.yaml'
TEMP_TEST_LOG='/tmp/AdGuardHometest.log'
UPDATE_LOG='/tmp/AdGuardHome_update.log'
SYSLOG_TEMP='/tmp/AdGuardHometmp.log'
UPDATE_SCRIPT="${IPKG_INSTROOT}/usr/share/AdGuardHome/update_core.sh"
GFW_SCRIPT="${IPKG_INSTROOT}/usr/share/AdGuardHome/gfw2adg.sh"
GFW_IPSET_SCRIPT="${IPKG_INSTROOT}/usr/share/AdGuardHome/gfwipset2adg.sh"
GFW_RULE_FILE="${IPKG_INSTROOT}/etc/AdGuardHome/gfw_upstream.txt"
SYSLOG_SCRIPT="${IPKG_INSTROOT}/usr/share/AdGuardHome/getsyslog.sh"

get_option() {
	local option="$1" fallback="$2" value
	value=$(uci -q get "$CONFIG_NAME.$CONFIG_NAME.$option" 2>/dev/null)
	[ -n "$value" ] && printf '%s\n' "$value" || printf '%s\n' "$fallback"
}

resolve_binpath() {
	local path="$1" parent
	[ -n "$path" ] || path="$DEFAULT_BINPATH"
	while [ "${path%/}" != "$path" ]; do
		path="${path%/}"
	done
	[ -n "$path" ] || path="$DEFAULT_BINPATH"
	parent="${path%/*}"
	if [ "${path##*/}" = 'AdGuardHome' ] && [ "$parent" != "$path" ] && [ "${parent##*/}" = 'AdGuardHome' ] && [ -e "$parent" ] && [ ! -d "$parent" ]; then
		path="$parent"
	fi
	if [ -d "$path" ]; then
		printf '%s/AdGuardHome\n' "$path"
	else
		printf '%s\n' "$path"
	fi
}

normalize_runtime_path() {
	local path="$1" fallback="$2" binpath="$3" mode="$4" parent
	[ -n "$path" ] || path="$fallback"
	while [ "${path%/}" != "$path" ]; do
		path="${path%/}"
	done
	[ -n "$path" ] || path="$fallback"
	case "$path" in
		"$binpath"|"$binpath"/*) path="$fallback" ;;
	esac
	if [ "$mode" = 'dir' ] && [ -e "$path" ] && [ ! -d "$path" ]; then
		path="$fallback"
	fi
	parent="${path%/*}"
	if [ "$parent" != "$path" ] && [ -e "$parent" ] && [ ! -d "$parent" ]; then
		path="$fallback"
	fi
	printf '%s\n' "$path"
}

resolve_configpath() {
	local raw="$1" binpath="$2"
	normalize_runtime_path "$raw" "$DEFAULT_CONFIGPATH" "$binpath" file
}

resolve_workdir() {
	local raw="$1" binpath="$2"
	normalize_runtime_path "$raw" "$DEFAULT_WORKDIR" "$binpath" dir
}

json_bool() {
	case "$2" in 1|true|yes|on) json_add_boolean "$1" 1 ;; *) json_add_boolean "$1" 0 ;; esac
}

safe_cat() {
	[ -r "$1" ] || return 1
	cat "$1" 2>/dev/null
}

normalize_arch() {
	case "$1" in
		auto|'') printf '%s\n' auto ;;
		386|i386) printf '%s\n' 386 ;;
		amd64|x86_64) printf '%s\n' amd64 ;;
		armv5|armv6|armv7|arm64|aarch64) [ "$1" = aarch64 ] && printf '%s\n' arm64 || printf '%s\n' "$1" ;;
		mips|mips_softfloat) printf '%s\n' mips_softfloat ;;
		mips64|mips64_softfloat) printf '%s\n' mips64_softfloat ;;
		mipsel|mipsle_softfloat) printf '%s\n' mipsle_softfloat ;;
		mips64el|mips64le_softfloat) printf '%s\n' mips64le_softfloat ;;
		powerpc64|ppc64le) printf '%s\n' ppc64le ;;
		*) printf '%s\n' auto ;;
	esac
}

normalize_channel() {
	case "$1" in release|beta|github|custom) printf '%s\n' "$1" ;; *) printf '%s\n' release ;; esac
}

normalize_redirect() {
	case "$1" in
		none|dnsmasq-upstream|redirect|exchange) printf '%s\n' "$1" ;;
		''|*) printf '%s\n' "$DEFAULT_REDIRECT" ;;
	esac
}

resolve_dns_port() {
	# Section-aware resolver: only returns port under the dns: block,
	# ignoring any other port: keys at different YAML levels.
	[ -r "$1" ] || return 1
	awk '
	BEGIN { in_dns = 0 }
	/^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
	/^[^[:space:]#][A-Za-z0-9_-]*:[[:space:]]*/ {
		in_dns = ($0 ~ /^dns:[[:space:]]*($|#)/)
		next
	}
	in_dns && /^[[:space:]]+port:[[:space:]]*/ {
		sub(/^[[:space:]]*port:[[:space:]]*/, "", $0)
		sub(/[[:space:]]+#.*$/, "", $0)
		gsub(/["\x27]/, "", $0)
		print $0
		exit
	}' "$1" 2>/dev/null
}

resolve_core_version() {
	local binpath="$1" version
	[ -x "$binpath" ] || return 1
	version=$($binpath --version 2>/dev/null | grep -m 1 -oE 'v?[0-9]+[.][A-Za-z0-9._-]+')
	[ -n "$version" ] || return 1
	printf '%s\n' "$version"
}

read_log_window() {
	local file="$1" pos="$2" bytes="$3" size count
	LOG_CONTENT=''
	LOG_POS=0
	LOG_SIZE=0
	[ -r "$file" ] || return 1
	size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
	case "$size" in ''|*[!0-9]*) size=0 ;; esac
	case "$pos" in ''|*[!0-9]*) pos=0 ;; esac
	case "$bytes" in ''|*[!0-9]*) bytes=32768 ;; esac
	[ "$pos" -le "$size" ] 2>/dev/null || pos=0
	count=$((size - pos))
	[ "$count" -le "$bytes" ] 2>/dev/null || count="$bytes"
	if [ "$count" -gt 0 ] 2>/dev/null; then
		LOG_CONTENT=$(dd if="$file" bs=1 skip="$pos" count="$count" 2>/dev/null | tr -d '\000')
		LOG_POS=$((pos + count))
	else
		LOG_POS="$size"
	fi
	LOG_SIZE="$size"
}

read_log_snapshot() {
	local file="$1" bytes="$2" size
	LOG_CONTENT=''
	LOG_POS=0
	LOG_SIZE=0
	[ -r "$file" ] || return 1
	size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
	case "$size" in ''|*[!0-9]*) size=0 ;; esac
	case "$bytes" in ''|*[!0-9]*) bytes=32768 ;; esac
	if [ "$size" -gt 0 ] 2>/dev/null; then
		LOG_CONTENT=$(tail -c "$bytes" "$file" 2>/dev/null | tr -d '\000')
	fi
	LOG_POS="$size"
	LOG_SIZE="$size"
}

backup_choices() {
	local workdir="$1" seen=' filters stats.db querylog.json sessions.db ' result='filters stats.db querylog.json sessions.db' entry
	if [ -d "$workdir/data" ]; then
		for entry in "$workdir"/data/*; do
			[ -e "$entry" ] || continue
			entry=${entry##*/}
			case " $seen " in *" $entry "*) ;; *) seen="$seen$entry "; result="$result $entry" ;; esac
		done
	fi
	printf '%s\n' "$result"
}

build_template() {
	local dns_values='' cnt nameserver line trimmed indent resolv
	resolv=$(uci -q get dhcp.@dnsmasq[0].resolvfile 2>/dev/null)
	[ -n "$resolv" ] || resolv='/tmp/resolv.conf.d/resolv.conf.auto'
	[ -r "$resolv" ] || resolv='/tmp/resolv.conf.auto'
	if [ -r "$resolv" ]; then
		while IFS= read -r cnt; do
			nameserver=$(printf '%s\n' "$cnt" | sed -n 's/^[^#]*nameserver[[:space:]]\+\([^[:space:]]\+\).*$/\1/p')
			[ -n "$nameserver" ] && dns_values="$dns_values$nameserver\n"
		done < "$resolv"
	fi
	[ -r "$TEMPLATE_FILE" ] || return 1
	while IFS= read -r line || [ -n "$line" ]; do
		trimmed=${line#"${line%%[![:space:]]*}"}
		indent=${line%"$trimmed"}
		case "$trimmed" in
			'#bootstrap_dns'|'#upstream_dns')
				printf '%b' "$dns_values" | while IFS= read -r nameserver; do
					[ -n "$nameserver" ] && printf '%s- %s\n' "$indent" "$nameserver"
				done
				;;
			*)
				printf '%s\n' "$line"
				;;
		esac
	done < "$TEMPLATE_FILE"
}

json_status() {
	local raw_binpath raw_configpath raw_workdir binpath configpath workdir logfile httpport redirect effective_redirect redirect_conflict redirect_compat redirect_compat_upstream version dns_port arch channel gfw_rules_present
	raw_binpath=$(get_option binpath "$DEFAULT_BINPATH")
	binpath=$(resolve_binpath "$raw_binpath")
	raw_configpath=$(get_option configpath "$DEFAULT_CONFIGPATH")
	configpath=$(resolve_configpath "$raw_configpath" "$binpath")
	raw_workdir=$(get_option workdir "$DEFAULT_WORKDIR")
	workdir=$(resolve_workdir "$raw_workdir" "$binpath")
	logfile=$(get_option logfile '')
	httpport=$(get_option httpport 3000)
	redirect=$(normalize_redirect "$(get_option redirect "$DEFAULT_REDIRECT")")
	effective_redirect=$(safe_cat /var/run/AdGeffective 2>/dev/null | head -n 1)
	[ -n "$effective_redirect" ] && effective_redirect=$(normalize_redirect "$effective_redirect") || effective_redirect="$redirect"
	redirect_conflict=$(safe_cat /var/run/AdGredirect_conflict 2>/dev/null | head -n 1)
	redirect_compat=$(safe_cat /var/run/AdGredirect_compat 2>/dev/null | head -n 1)
	redirect_compat_upstream=$(safe_cat /var/run/AdGredirect_compat_upstream 2>/dev/null | head -n 1)
	arch=$(normalize_arch "$(get_option downloadarch "$(get_option arch auto)")")
	channel=$(normalize_channel "$(get_option release_channel "$(get_option tagname release)")")
	version=$(resolve_core_version "$binpath" 2>/dev/null)
	dns_port=$(resolve_dns_port "$configpath" 2>/dev/null)
	gfw_rules_present=0
	[ -s "$GFW_RULE_FILE" ] && gfw_rules_present=1
	[ "$gfw_rules_present" = 1 ] || grep -qm 1 programadd "$configpath" 2>/dev/null && gfw_rules_present=1
	json_init
	json_add_string binpath "$binpath"
	json_add_string configpath "$configpath"
	json_add_string workdir "$workdir"
	json_add_string logfile "$logfile"
	json_add_string httpport "$httpport"
	json_add_string redirect "$redirect"
	json_add_string effective_redirect "$effective_redirect"
	json_add_string redirect_conflict_reason "$redirect_conflict"
	json_add_string redirect_compat_reason "$redirect_compat"
	json_add_string redirect_compat_upstream "${redirect_compat_upstream:-}"
	json_add_string version "${version:-unknown}"
	json_add_string dns_port "${dns_port:-unknown}"
	json_add_string downloadarch "$arch"
	json_add_string release_channel "$channel"
	json_bool enabled "$(get_option enabled 0)"
	json_bool running "$(pgrep -f "$binpath" >/dev/null 2>&1 && echo 1 || echo 0)"
	json_bool redirected "$([ "$(cat /var/run/AdGredir 2>/dev/null)" = 1 ] && echo 1 || echo 0)"
	json_bool redirect_conflict "$([ -n "$redirect_conflict" ] && echo 1 || echo 0)"
	json_bool redirect_compat "$([ -n "$redirect_compat" ] && echo 1 || echo 0)"
	json_bool core_ready "$([ -x "$binpath" ] && echo 1 || echo 0)"
	json_bool config_ready "$([ -r "$configpath" ] && echo 1 || echo 0)"
	json_bool workdir_ready "$([ -d "$workdir" ] && echo 1 || echo 0)"
	json_bool update_running "$([ -e /var/run/update_core ] && echo 1 || pgrep -f '/usr/share/AdGuardHome/update_core.sh' >/dev/null 2>&1 && echo 1 || echo 0)"
	json_bool gfw_added "$gfw_rules_present"
	json_bool ipset_added "$(grep -qm 1 'ipset_file:.*ipset.txt' "$configpath" 2>/dev/null && echo 1 || echo 0)"
	json_dump
}

json_meta() {
	local raw_binpath binpath raw_workdir workdir links choices one
	raw_binpath=$(get_option binpath "$DEFAULT_BINPATH")
	binpath=$(resolve_binpath "$raw_binpath")
	raw_workdir=$(get_option workdir "$DEFAULT_WORKDIR")
	workdir=$(resolve_workdir "$raw_workdir" "$binpath")
	links=$(safe_cat "$LINKS_FILE")
	choices=$(backup_choices "$workdir")
	json_init
	json_add_string links "$links"
	json_add_array backup_choices
	for one in $choices; do json_add_string '' "$one"; done
	json_close_array
	json_add_array release_channels
	for one in release beta github custom; do json_add_string '' "$one"; done
	json_close_array
	json_add_array download_arches
	for one in auto 386 amd64 armv5 armv6 armv7 arm64 mips_softfloat mips64_softfloat mipsle_softfloat mips64le_softfloat ppc64le; do json_add_string '' "$one"; done
	json_close_array
	json_dump
}

json_yaml() {
	local raw_binpath raw_configpath binpath configpath content source test_log current_exists template_content
	raw_binpath=$(get_option binpath "$DEFAULT_BINPATH")
	binpath=$(resolve_binpath "$raw_binpath")
	raw_configpath=$(get_option configpath "$DEFAULT_CONFIGPATH")
	configpath=$(resolve_configpath "$raw_configpath" "$binpath")
	current_exists=0
	[ -r "$configpath" ] && current_exists=1
	if [ -f "$TEMP_CONFIG" ] && [ -s "$TEMP_CONFIG" ]; then
		source=temp
		content=$(safe_cat "$TEMP_CONFIG")
	elif [ "$current_exists" = 1 ]; then
		source=config
		content=$(safe_cat "$configpath")
	elif template_content=$(build_template 2>/dev/null) && [ -n "$template_content" ]; then
		source=template
		content="$template_content"
	else
		source=template
		content=''
	fi
	test_log=$(safe_cat "$TEMP_TEST_LOG")
	json_init
	json_add_string source "$source"
	json_add_string content "$content"
	json_bool current_exists "$current_exists"
	json_add_string test_log "$test_log"
	json_dump
}

json_current_yaml() {
	local raw_binpath raw_configpath binpath configpath content
	raw_binpath=$(get_option binpath "$DEFAULT_BINPATH")
	binpath=$(resolve_binpath "$raw_binpath")
	raw_configpath=$(get_option configpath "$DEFAULT_CONFIGPATH")
	configpath=$(resolve_configpath "$raw_configpath" "$binpath")
	content=$(safe_cat "$configpath")
	json_init
	json_bool current_exists "$([ -r "$configpath" ] && echo 1 || echo 0)"
	json_add_string content "$content"
	json_dump
}

save_yaml() {
	local input content raw_binpath raw_configpath binpath configpath
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var content content
	raw_binpath=$(get_option binpath "$DEFAULT_BINPATH")
	binpath=$(resolve_binpath "$raw_binpath")
	raw_configpath=$(get_option configpath "$DEFAULT_CONFIGPATH")
	configpath=$(resolve_configpath "$raw_configpath" "$binpath")
	if pgrep -f "$binpath" >/dev/null 2>&1; then
		json_init; json_add_boolean ok 0; json_add_string error 'AdGuard Home is running. Stop the service before saving YAML.'; json_dump; return
	fi
	mkdir -p "${configpath%/*}" 2>/dev/null
	rm -rf "$TEMP_CONFIG"
	rm -f "$TEMP_TEST_LOG"
	printf '%s' "$content" > "$TEMP_CONFIG"
	if [ -x "$binpath" ]; then
		if ! "$binpath" -c "$TEMP_CONFIG" --check-config > "$TEMP_TEST_LOG" 2>&1; then
			json_init; json_add_boolean ok 0; json_add_string error "$(safe_cat "$TEMP_TEST_LOG")"; json_dump; return
		fi
	fi
	mv -f "$TEMP_CONFIG" "$configpath"
	rm -f "$TEMP_TEST_LOG"
	/etc/init.d/AdGuardHome reload >/dev/null 2>&1 &
	json_init; json_add_boolean ok 1; json_dump
}

get_log() {
	local input scope pos file running logfile
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var scope scope
	json_get_var pos position
	[ -n "$scope" ] || scope=runtime
	if [ "$scope" = update ]; then
		file="$UPDATE_LOG"
		running=$([ -e /var/run/update_core ] && echo 1 || echo 0)
	else
		logfile=$(get_option logfile '')
		if [ -z "$logfile" ] || [ "$logfile" = syslog ]; then
			if [ -x "$SYSLOG_SCRIPT" ] && ! pgrep -f '/usr/share/AdGuardHome/getsyslog.sh' >/dev/null 2>&1; then
				"$SYSLOG_SCRIPT" >/dev/null 2>&1 &
			fi
			printf 1 > /var/run/AdGuardHomesyslog 2>/dev/null
			file="$SYSLOG_TEMP"
		else
			file="$logfile"
		fi
		running=0
	fi
	if [ "$pos" -eq 0 ] 2>/dev/null; then
		read_log_snapshot "$file" 32768 || true
	else
		read_log_window "$file" "$pos" 32768 || true
	fi
	json_init
	json_add_string scope "$scope"
	json_add_string content "$LOG_CONTENT"
	json_add_int position "$LOG_POS"
	json_add_int size "$LOG_SIZE"
	json_bool running "$running"
	json_dump
}

clear_log() {
	local input scope logfile file
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var scope scope
	if [ "$scope" = update ]; then
		file="$UPDATE_LOG"
	else
		logfile=$(get_option logfile '')
		if [ -z "$logfile" ] || [ "$logfile" = syslog ]; then
			file="$SYSLOG_TEMP"
		else
			file="$logfile"
		fi
	fi
	[ -n "$file" ] && : > "$file" 2>/dev/null
	json_init; json_add_boolean ok 1; json_dump
}

start_update() {
	local input force arg
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var force force
	[ "$force" = 1 ] || [ "$force" = true ] && arg=force || arg=''
	if [ -e /var/run/update_core ] && pgrep -f '/usr/share/AdGuardHome/update_core.sh' >/dev/null 2>&1; then
		json_init; json_add_boolean ok 0; json_add_string message 'An update task is already running.'; json_dump
		return 0
	fi
	: >> "$UPDATE_LOG"
	sh "$UPDATE_SCRIPT" $arg >> "$UPDATE_LOG" 2>&1 &
	json_init; json_add_boolean ok 1; json_dump
}

run_script_action() {
	local script="$1" arg="$2" logfile="$3" output
	: > "$logfile"
	if [ -n "$arg" ]; then
		sh "$script" "$arg" > "$logfile" 2>&1
	else
		sh "$script" > "$logfile" 2>&1
	fi
	if [ "$?" -eq 0 ]; then
		json_init; json_add_boolean ok 1; json_dump
		return
	fi
	output=$(safe_cat "$logfile")
	json_init
	json_add_boolean ok 0
	json_add_string error "${output:-Script action failed.}"
	json_dump
}

gfw_action() {
	local input action script arg
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var action action
	case "$action" in
		add) run_script_action "$GFW_SCRIPT" '' /tmp/AdGuardHome_gfw.log; return ;;
		del) run_script_action "$GFW_SCRIPT" del /tmp/AdGuardHome_gfw.log; return ;;
		import) "$GFW_SCRIPT" import; return ;;
		remove_import) "$GFW_SCRIPT" remove_import; return ;;
		ipset_add) script="$GFW_IPSET_SCRIPT"; arg='' ;;
		ipset_del) script="$GFW_IPSET_SCRIPT"; arg=del ;;
		*) json_init; json_add_boolean ok 0; json_add_string error 'invalid action'; json_dump; return ;;
	esac
	sh "$script" $arg > /tmp/AdGuardHome_gfw.log 2>&1 &
	json_init; json_add_boolean ok 1; json_dump
}

set_links() {
	local input content channel arch legacy_arch
	input=$(cat)
	json_load "$input" >/dev/null 2>&1
	json_get_var content content
	json_get_var channel channel
	json_get_var arch download_arch
	channel=$(normalize_channel "$channel")
	arch=$(normalize_arch "$arch")
	mkdir -p "${LINKS_FILE%/*}" 2>/dev/null
	printf '%s\n' "$content" | sed 's/\r$//' > "$LINKS_FILE"
	case "$arch" in 386) legacy_arch=386 ;; amd64) legacy_arch=amd64 ;; arm64) legacy_arch=arm64 ;; ppc64le) legacy_arch=ppc64le ;; auto) legacy_arch='' ;; *) legacy_arch="$arch" ;; esac
	uci set "$CONFIG_NAME.$CONFIG_NAME.release_channel=$channel"
	uci set "$CONFIG_NAME.$CONFIG_NAME.tagname=$channel"
	uci set "$CONFIG_NAME.$CONFIG_NAME.downloadarch=$arch"
	uci set "$CONFIG_NAME.$CONFIG_NAME.arch=$legacy_arch"
	uci commit "$CONFIG_NAME"
	json_init; json_add_boolean ok 1; json_dump
}

_json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

_http_get() {
	local url="$1" timeout="${2:-5}" user="${3:-}" pass="${4:-}" cookie_file="${5:-}"

	if command -v curl >/dev/null 2>&1; then
		set -- -sSL --connect-timeout "$timeout" --max-time "$((timeout + 2))"
		[ -n "$cookie_file" ] && [ -s "$cookie_file" ] && set -- "$@" --cookie "$cookie_file"
		[ -n "$user" ] && [ -n "$pass" ] && set -- "$@" -u "$user:$pass"
		curl "$@" "$url" 2>/dev/null
	elif command -v wget-ssl >/dev/null 2>&1; then
		set -- -qO- -T "$timeout"
		[ -n "$cookie_file" ] && [ -s "$cookie_file" ] && set -- "$@" --load-cookies="$cookie_file"
		[ -n "$user" ] && [ -n "$pass" ] && set -- "$@" --user="$user" --password="$pass"
		wget-ssl "$@" "$url" 2>/dev/null
	elif command -v wget >/dev/null 2>&1; then
		set -- -qO- -T "$timeout"
		[ -n "$cookie_file" ] && [ -s "$cookie_file" ] && set -- "$@" --load-cookies="$cookie_file"
		[ -n "$user" ] && [ -n "$pass" ] && set -- "$@" --user="$user" --password="$pass"
		wget "$@" "$url" 2>/dev/null
	fi
}

_http_post_json() {
	local url="$1" payload="$2" timeout="${3:-5}" cookie_file="${4:-}"

	if command -v curl >/dev/null 2>&1; then
		set -- -sSL --connect-timeout "$timeout" --max-time "$((timeout + 2))" -H 'Content-Type: application/json' --data "$payload"
		[ -n "$cookie_file" ] && set -- "$@" --cookie-jar "$cookie_file" --cookie "$cookie_file"
		curl "$@" "$url" 2>/dev/null
	elif command -v wget-ssl >/dev/null 2>&1; then
		set -- -qO- -T "$timeout" --header='Content-Type: application/json' --post-data="$payload"
		[ -n "$cookie_file" ] && set -- "$@" --save-cookies="$cookie_file" --keep-session-cookies
		wget-ssl "$@" "$url" 2>/dev/null
	elif command -v wget >/dev/null 2>&1; then
		set -- -qO- -T "$timeout" --header='Content-Type: application/json' --post-data="$payload"
		[ -n "$cookie_file" ] && set -- "$@" --save-cookies="$cookie_file" --keep-session-cookies
		wget "$@" "$url" 2>/dev/null
	fi
}

_is_stats_payload() {
	printf '%s\n' "$1" | grep -q '"num_dns_queries"'
}

_auth_get() {
	local url="$1" timeout="${2:-5}"
	local user pass data base_url login_url cookie_file login_payload
	user=$(get_option username root)
	pass=$(get_option password admin)

	data=$(_http_get "$url" "$timeout")
	if _is_stats_payload "$data"; then
		printf '%s\n' "$data"
		return
	fi

	data=$(_http_get "$url" "$timeout" "$user" "$pass")
	if _is_stats_payload "$data"; then
		printf '%s\n' "$data"
		return
	fi

	if [ -n "$user" ] && [ -n "$pass" ]; then
		base_url="${url%/control/*}"
		login_url="$base_url/control/login"
		cookie_file="/tmp/AdGuardHome_rpcd_cookie.$$"
		login_payload=$(printf '{"name":"%s","password":"%s"}' "$(_json_escape "$user")" "$(_json_escape "$pass")")
		_http_post_json "$login_url" "$login_payload" "$timeout" "$cookie_file" >/dev/null
		data=$(_http_get "$url" "$timeout" '' '' "$cookie_file")
		rm -f "$cookie_file"
		if _is_stats_payload "$data"; then
			printf '%s\n' "$data"
			return
		fi
	fi

	printf '%s\n' "$data"
}

_json_extract_int() {
	printf '%s\n' "$1" | awk -v key="$2" '
		BEGIN { RS=","; FS=":" }
		$0 ~ "\"" key "\"" {
			gsub(/[^0-9-]/, "", $2)
			print $2
			exit
		}
	'
}

_json_extract_float() {
	printf '%s\n' "$1" | awk -v key="$2" '
		BEGIN { RS=","; FS=":" }
		$0 ~ "\"" key "\"" {
			gsub(/[^0-9.eE+-]/, "", $2)
			print $2
			exit
		}
	'
}

json_stats() {
	local httpport data running
	httpport=$(get_option httpport 3000)

	if ! pgrep -f "$(resolve_binpath "$(get_option binpath "$DEFAULT_BINPATH")" 2>/dev/null || echo ADGUARDHOME_RUNNING_CHECK)" >/dev/null 2>&1; then
		json_init
		json_add_boolean ok 0
		json_add_string error 'AdGuard Home is not running.'
		json_dump
		return
	fi

	data=$(_auth_get "http://127.0.0.1:$httpport/control/stats" 5)
	if [ -z "$data" ]; then
		json_init
		json_add_boolean ok 0
		json_add_string error 'Unable to fetch stats from AdGuard Home API. Check that AdGuard Home is running on port '"$httpport"' and that the saved web login credentials match the AdGuard Home admin account.'
		json_dump
		return
	fi

	if printf '%s\n' "$data" | grep -q '"num_dns_queries"'; then
		json_init
		json_add_boolean ok 1
		json_add_int num_dns_queries "$(_json_extract_int "$data" num_dns_queries)"
		json_add_int num_blocked_filtering "$(_json_extract_int "$data" num_blocked_filtering)"
		json_add_string avg_processing_time "$(_json_extract_float "$data" avg_processing_time)"
		json_dump
	else
		json_init
		json_add_boolean ok 0
		json_add_string error "$(printf '%s' "$data" | head -c 256)"
		json_dump
	fi
}

list_methods() {
	cat <<'JSON'
{"getStatus":{},"getMeta":{},"getYaml":{},"getCurrentYaml":{},"getTemplateConfig":{},"saveYaml":{"content":"string"},"discardYaml":{},"getLog":{"scope":"string","position":"number"},"clearLog":{"scope":"string"},"startUpdate":{"force":"boolean"},"gfwAction":{"action":"string"},"setLinks":{"content":"string","channel":"string","download_arch":"string"},"getStats":{}}
JSON
}

case "$1" in
	list) list_methods ;;
	call)
		case "$2" in
			getStatus) json_status ;;
			getMeta) json_meta ;;
			getStats) json_stats ;;
			getYaml) json_yaml ;;
			getCurrentYaml) json_current_yaml ;;
			getTemplateConfig) json_init; json_add_string content "$(build_template)"; json_dump ;;
			saveYaml) save_yaml ;;
			discardYaml) rm -rf "$TEMP_CONFIG"; rm -f "$TEMP_TEST_LOG"; json_init; json_add_boolean ok 1; json_dump ;;
			getLog) get_log ;;
			clearLog) clear_log ;;
			startUpdate) start_update ;;
			gfwAction) gfw_action ;;
			setLinks) set_links ;;
			*) json_init; json_add_string error 'unknown method'; json_dump; exit 1 ;;
		esac
		;;
	*) exit 1 ;;
esac
